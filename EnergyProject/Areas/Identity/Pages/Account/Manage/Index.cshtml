@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number."/>
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>

<div class="card card-muted">
    <div class="card-header">
        <span class="card-pill">Information</span>
    </div>
    <h2 class="card-title">Data &amp; security</h2>
    <p class="card-text">
        For security reasons we do not display your password here.
        If you need to change it, use the password change function in the application.
    </p>
    <p class="card-text mt-12">
        Make sure your email and phone number are always up to date so we can contact you
        about your consumption and payments.
    </p>
    <p class="card-footer">
        <a class="user-btn user-btn-primary"
           asp-area="Client"
           asp-controller="CardData"
           asp-action="Show">
            View my cards
        </a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
