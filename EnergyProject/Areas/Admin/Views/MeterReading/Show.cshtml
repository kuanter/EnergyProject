@using System.Linq
@model IEnumerable<EnergyProject.Models.MeterReading>

@{
    ViewData["Title"] = "Meter Readings";
    var readings = Model?.ToList() ?? new List<EnergyProject.Models.MeterReading>();
}

<link rel="stylesheet" href="~/css/admin-users.css" />

<section class="page">
    <div class="toolbar">
        <div>
            <h1 class="h1">Meter Readings</h1>
            <p class="lead">List of generated readings for the selected meter</p>
            <p>ID:  @readings.FirstOrDefault()?.MeterId </p>
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn"
               asp-area="Admin"
               asp-controller="Meter"
               asp-action="Show">
                Back to Meters
            </a>

            <button type="button" class="btn" onclick="location.reload();">
                Refresh
            </button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Date</th>
                    <th>Value (kWh)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td><span class="chip chip-dark">@item.ValueKWh kWh</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <h4>No readings available</h4>
        </div>
    }
</section>