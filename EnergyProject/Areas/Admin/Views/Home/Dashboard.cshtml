@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4">Admin Dashboard</h1>
            <p class="lead">Welcome to the Energy Project management panel.</p>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mt-2">Users</h5>
                    <p class="card-text text-muted">Manage system users, clients, and admins.</p>
                    <a asp-controller="User" asp-action="Show" class="btn btn-outline-secondary mt-2">Manage Users</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mt-2">Meters</h5>
                    <p class="card-text text-muted">Manage client meters and view details.</p>
                    <a asp-controller="Meter" asp-action="Show" class="btn btn-outline-primary mt-2">Manage Meters</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mt-2">Power Status</h5>
                    <p class="card-text text-muted">Update area power availability and outages.</p>
                    <a asp-controller="PowerStatus" asp-action="Show" class="btn btn-outline-warning mt-2">Manage Power Status</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mt-2">Tariffs</h5>
                    <p class="card-text text-muted">Configure pricing and energy tariffs.</p>
                    <a asp-controller="Tariff" asp-action="Show" class="btn btn-outline-success mt-2">Manage Tariffs</a>
                </div>
            </div>
        </div>
    </div>
</div>