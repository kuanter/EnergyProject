@using System.Linq
@model IEnumerable<EnergyProject.Models.PaymentAccount>


<link rel="stylesheet" href="~/css/user.css" />

<section class="page">
    <div class="page-header">
        <div>
            <h1 class="h1">Payment accounts</h1>
            <p class="lead">
                List of all payment accounts linked to your profile.
            </p>
        </div>
        <div class="page-header-actions">
            <a class="user-btn user-btn-primary"
               asp-area="Client"
               asp-controller="PaymentAccount"
               asp-action="Create">
                Create payment account
            </a>
        </div>
    
       
    </div>

    <div class="card mt-24">
        <div class="table-wrapper">
            <table class="user-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>User Id</th>
                        <th>Address</th>
                        <th>Tariff</th>
                        <th>Meter Id</th>
                        <th>Power status Id</th>
                        <th>Bills</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr class="empty-row">
                            <td colspan="7">There are no payment accounts yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var pa in Model)
                        {
                            <tr>
                                <td data-label="Id" title="@pa.Id">@pa.Id.Substring(0, 8)...</td>

                                <td data-label="User Id" title="@pa.UserId">@pa.UserId.Substring(0, 8)...</td>

                                <td data-label="Address">
                                    @if (pa.Address != null)
                                    {
                                        <span>@pa.Address.City, @pa.Address.Street @pa.Address.House, @pa.Address.Apartment</span>
                                    }
                                    else
                                    {
                                        <span style="color: red;">Address not found</span>
                                    }
                                </td>

                                <td data-label="Tariff">@(pa.Tariff?.Name ?? "No tariff")</td>

                                @if (pa.Meter != null)
                                {
                                    <td data-label="Meter Id">@pa.Meter.SerialNumber</td>
                                }
                                else
                                {
                                    <td data-label="Meter Id">NULL</td>
                                }

                            
                                <td data-label="PowerStatus">@(pa.PowerStatus?.Status ?? "Unknown")</td>

                                <td data-label="Bills">
                                    <a class="user-btn user-btn-primary"
                                       asp-area="Client"
                                       asp-controller="Bill"
                                       asp-action="Show"
                                       asp-route-id="@pa.Id">
                                        Bills
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
