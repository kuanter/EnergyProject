@using System.Linq
@model IEnumerable<EnergyProject.Models.CardData>

<link rel="stylesheet" href="~/css/user.css" />

<section class="page">
    <div class="page-header">
        <div>
            <h1 class="h1">Card Data</h1>
            <p class="lead">
                List of all card linked to your profile.
            </p>
        </div>
        <div class="page-header-actions">
            <a class="user-btn user-btn-primary" href="Create">
                Create Card
            </a>
        </div>
    </div>

    <div class="card mt-24">
        <div class="table-wrapper">
            <table class="user-table">
                <tbody>
                    @if (Model == null)
                    {
                        <div class="alert alert-info text-center" role="alert">
                            <h4>No CardData available</h4>
                        </div>
                    }
                    else
                    {
                        <thead>
                            <tr>
                                <th>Card Number</th>
                                <th>Card Name</th>
                                <th>Default</th>
                                <th>Set as Default</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td data-label="Address Id">@c.CardNumber</td>
                                <td data-label="Meter Id">@c.CardName</td>
                                <td data-label="Meter Id">@c.IsDefault</td>
                                <td><a class="user-btn user-btn-primary" asp-area="Client" asp-controller="CardData" asp-action="SetAsDefault" asp-route-Id="@c.Id">Set As Default</a></td>
                                <td><a class="user-btn user-btn-primary" asp-area="Client" asp-controller="CardData" asp-action="Delete" asp-route-Id="@c.Id">Delete</a></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
