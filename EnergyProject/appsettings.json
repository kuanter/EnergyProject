{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EnergyProjectDB;Trusted_Connection=True;MultipleActiveResultSets=true",
    "EnergyProjectContextConnection": "Server=(localdb)\\mssqllocaldb;Database=EnergyProject;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "File": {
      "Path": "Logs/log-.txt",
      "RollingInterval": "Day",
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
    }
  },
  "AllowedHosts": "*"
}
